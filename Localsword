local ReplicatedStorage = game:GetService("ReplicatedStorage")

local tool = script.Parent
local handle = tool:WaitForChild("Handle")
local remote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SwordHit")

local ATTACK_COOLDOWN = 0.2
local LUNGE_WINDOW = 0.5
local ATTACK_ACTIVE_WINDOW = 0.35
local TOUCH_REPEAT_COOLDOWN = 0.12
local LUNGE_RECOVERY = 1.0

local lastActivate = 0
local attackUntil = 0
local touchCooldownByPart = {}
local lungeLockUntil = 0

local function send(action, hit)
	remote:FireServer({
		action = action,
		hit = hit,
		tool = tool,
	})
end

local function playLocalAttackFeedback(attackType)
	local soundName = attackType == "lunge" and "SwordLunge" or "SwordSlash"
	local sound = handle:FindFirstChild(soundName)
	if sound then
		sound:Play()
	end

	local anim = Instance.new("StringValue")
	anim.Name = "toolanim"
	anim.Value = attackType == "lunge" and "Lunge" or "Slash"
	anim.Parent = tool

	if attackType == "lunge" then
		tool.GripUp = Vector3.new(0, 0, 0)
		task.delay(0.75, function()
			if tool and tool.Parent then
				tool.GripUp = Vector3.new(0, 0, 1)
			end
		end)
	end
end

tool.Equipped:Connect(function()
	local unsheath = handle:FindFirstChild("Unsheath")
	if unsheath then
		unsheath:Play()
	end
end)

tool.Activated:Connect(function()
	local now = tick()
	if now < lungeLockUntil then
		return
	end
	if now - lastActivate < ATTACK_COOLDOWN then
		return
	end

	local attackType = (now - lastActivate < LUNGE_WINDOW) and "lunge" or "slash"
	if attackType == "lunge" then
		lungeLockUntil = now + LUNGE_RECOVERY
	end
	lastActivate = now
	attackUntil = now + ATTACK_ACTIVE_WINDOW

	playLocalAttackFeedback(attackType)
	send("activate")
end)

handle.Touched:Connect(function(hit)
	local now = tick()
	if now > attackUntil then
		return
	end
	if not (hit and hit:IsA("BasePart")) then
		return
	end

	local nextAllowed = touchCooldownByPart[hit]
	if nextAllowed and now < nextAllowed then
		return
	end
	touchCooldownByPart[hit] = now + TOUCH_REPEAT_COOLDOWN
	send("touch", hit)
end)

handle.TouchEnded:Connect(function(hit)
	if hit then
		touchCooldownByPart[hit] = nil
	end
	send("touchEnd", hit)
end)
