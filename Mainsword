local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")
local CollectionService = game:GetService("CollectionService")

local KILL_TAG_LIFETIME = 5
local STUD_CAP = 13
local ATTACK_RESET = 0.2
local LUNGE_WINDOW = 0.5

local MONITORED_HUMANOIDS = {}
local PLAYER_STATE = {}

local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
if not remotesFolder then
	remotesFolder = Instance.new("Folder")
	remotesFolder.Name = "Remotes"
	remotesFolder.Parent = ReplicatedStorage
end

local swordRemote = remotesFolder:FindFirstChild("SwordHit")
if not swordRemote then
	swordRemote = Instance.new("RemoteEvent")
	swordRemote.Name = "SwordHit"
	swordRemote.Parent = remotesFolder
end

local function ensureLeaderstats(player)
	local leaderstats = player:FindFirstChild("leaderstats") or Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local kills = leaderstats:FindFirstChild("Kills") or Instance.new("IntValue")
	kills.Name = "Kills"
	kills.Parent = leaderstats

	local time = leaderstats:FindFirstChild("Time") or Instance.new("IntValue")
	time.Name = "Time"
	time.Parent = leaderstats
end

local function getVictimPlayer(humanoid)
	local userId = humanoid:GetAttribute("VictimUserId")
	if typeof(userId) == "number" then
		local p = Players:GetPlayerByUserId(userId)
		if p then return p end
	end
	return humanoid.Parent and Players:GetPlayerFromCharacter(humanoid.Parent) or nil
end

local function awardKill(humanoid)
	if humanoid:GetAttribute("KillAwarded") or humanoid:GetAttribute("KillProcessing") then return end
	humanoid:SetAttribute("KillProcessing", true)

	local creator = humanoid:FindFirstChild("creator")
	local killer = creator and creator.Value
	if not (killer and killer:IsA("Player")) then
		humanoid:SetAttribute("KillProcessing", nil)
		return
	end

	humanoid:SetAttribute("KillAwarded", true)
	ensureLeaderstats(killer)
	local killerStats = killer:FindFirstChild("leaderstats")
	local kills = killerStats and killerStats:FindFirstChild("Kills")
	local killerTime = killerStats and killerStats:FindFirstChild("Time")
	if not (kills and killerTime) then
		humanoid:SetAttribute("KillProcessing", nil)
		return
	end

	kills.Value += 1

	local victim = getVictimPlayer(humanoid)
	if victim then
		ensureLeaderstats(victim)
		local victimStats = victim:FindFirstChild("leaderstats")
		local victimTime = victimStats and victimStats:FindFirstChild("Time")
		if victimTime then
			local snap = humanoid:GetAttribute("VictimTimeSnapshot")
			local stolenTime = (typeof(snap) == "number" and snap >= 0) and snap or victimTime.Value
			killerTime.Value += stolenTime
			victimTime.Value = math.max(victimTime.Value - stolenTime, 0)

			local killFeed = ReplicatedStorage:FindFirstChild("KillFeed")
			if killFeed then
				local studs = 0
				if killer.Character and victim.Character then
					local kr = killer.Character:FindFirstChild("HumanoidRootPart")
					local vr = victim.Character:FindFirstChild("HumanoidRootPart")
					if kr and vr then studs = (kr.Position - vr.Position).Magnitude end
				end
				killFeed:Fire(killer.Name, victim.Name, studs, stolenTime)
			end
			local notif = remotesFolder:FindFirstChild("SendKillNotif")
			if notif then notif:FireClient(killer, victim) end
		end
	end

	humanoid:SetAttribute("KillProcessing", nil)
end

local function monitorHumanoid(humanoid)
	if MONITORED_HUMANOIDS[humanoid] then return end
	MONITORED_HUMANOIDS[humanoid] = true
	humanoid.Died:Connect(function() task.defer(awardKill, humanoid) end)
	humanoid.AncestryChanged:Connect(function(_, p)
		if not p then MONITORED_HUMANOIDS[humanoid] = nil end
	end)
end

local function getDamage(tool, isLunge)
	local handle = tool:FindFirstChild("Handle")
	local stats = handle and handle:FindFirstChild("Stats")
	if not stats then return 10 end
	local idle = stats:FindFirstChild("Idle")
	local slash = stats:FindFirstChild("Slash")
	local lunge = stats:FindFirstChild("Lunge")
	if isLunge and lunge then return lunge.Value end
	if slash then return slash.Value end
	return idle and idle.Value or 10
end

local function canDamage(attacker, victim)
	if not (attacker and victim) then return false end
	if attacker == victim then return false end
	local aSafe = CollectionService:HasTag(attacker, "safe")
	local vSafe = CollectionService:HasTag(victim, "safe")
	if aSafe and vSafe then return false end
	return true
end

swordRemote.OnServerEvent:Connect(function(player, payload)
	if typeof(payload) ~= "table" then return end
	local tool = payload.tool
	local hitPart = payload.hit
	if not (tool and tool:IsA("Tool") and hitPart and hitPart:IsA("BasePart")) then return end
	if tool.Parent ~= player.Character then return end

	local state = PLAYER_STATE[player] or { lastAttack = 0, isTouchingSafeY = false }
	PLAYER_STATE[player] = state

	if payload.action == "touchEnd" then
		local safezone = workspace:FindFirstChild("Safezone")
		local safePart = safezone and safezone:FindFirstChild("safey")
		if hitPart == safePart then state.isTouchingSafeY = false end
		return
	end

	local hum = hitPart.Parent and hitPart.Parent:FindFirstChild("Humanoid")
	if not (hum and hum.Health > 0 and player.Character) then return end
	if hum.Parent == player.Character then return end

	local safezone = workspace:FindFirstChild("Safezone")
	local safePart = safezone and safezone:FindFirstChild("safey")
	if hitPart == safePart then state.isTouchingSafeY = true return end
	if state.isTouchingSafeY then return end

	local handle = tool:FindFirstChild("Handle")
	local root = hitPart.Parent:FindFirstChild("HumanoidRootPart")
	if handle and root and (handle.Position - root.Position).Magnitude > STUD_CAP then return end

	local victimPlayer = Players:GetPlayerFromCharacter(hum.Parent)
	if victimPlayer and not canDamage(player, victimPlayer) then return end

	local now = tick()
	local isLunge = (now - state.lastAttack) < LUNGE_WINDOW
	state.lastAttack = now

	if victimPlayer then
		hum:SetAttribute("VictimUserId", victimPlayer.UserId)
		local vs = victimPlayer:FindFirstChild("leaderstats")
		local vt = vs and vs:FindFirstChild("Time")
		hum:SetAttribute("VictimTimeSnapshot", vt and vt.Value or 0)
	end

	local old = hum:FindFirstChild("creator")
	if old then old:Destroy() end
	local tag = Instance.new("ObjectValue")
	tag.Name = "creator"
	tag.Value = player
	tag.Parent = hum
	Debris:AddItem(tag, KILL_TAG_LIFETIME)

	monitorHumanoid(hum)
	hum:TakeDamage(getDamage(tool, isLunge))

	task.delay(ATTACK_RESET, function()
		if state == PLAYER_STATE[player] then end
	end)
end)

Players.PlayerAdded:Connect(ensureLeaderstats)
Players.PlayerRemoving:Connect(function(player)
	PLAYER_STATE[player] = nil
end)
for _, p in ipairs(Players:GetPlayers()) do
	ensureLeaderstats(p)
end
